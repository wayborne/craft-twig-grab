{
    "name": "wayborne/twig-grab",
    "description": "Hover over any element to see which Twig template rendered it",
    "type": "craft-plugin",
    "version": "1.0.0",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "twig-grab",
        "twig",
        "templates",
        "developer-tools"
    ],
    "support": {
        "email": "support@wayborne.com",
        "issues": "https://github.com/wayborne/craft-twig-grab/issues?state=open",
        "source": "https://github.com/wayborne/craft-twig-grab/",
        "docs": "https://github.com/wayborne/craft-twig-grab/"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Wayborne",
            "homepage": "https://wayborne.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "craftcms/cms": "^5.0.0"
    },
    "autoload": {
        "psr-4": {
            "wayborne\\twiggrab\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "wayborne\\twiggrab\\tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    },
    "extra": {
        "name": "Twig Grab",
        "handle": "twig-grab",
        "description": "Hover over any element to see which Twig template rendered it",
        "developer": "Wayborne",
        "documentationUrl": "https://github.com/wayborne/craft-twig-grab",
        "class": "wayborne\\twiggrab\\TwigGrab"
    }
}
